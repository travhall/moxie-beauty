# Copy to .env and fill in real values. Never commit .env — see .gitignore.

# Square API — required for the /api/square/webhook route to accept
# requests. The route fails closed (rejects all webhook calls) if
# SQUARE_WEBHOOK_SIGNATURE_KEY is unset. See app/api/square/webhook/route.ts.
SQUARE_ENVIRONMENT=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
NEXT_PUBLIC_SQUARE_APP_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=

# Google Maps — optional. Without this, the contact page shows a styled
# placeholder instead of a live map. See docs/google-maps-setup.md.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
